{
  "name": "leagues-ui",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
    "format:check": "oxfmt --check .",
    "validate-data": "tsx scripts/build-data.ts",
    "scrape": "tsx scripts/scrape-tasks.ts",
    "scrape:tasks": "tsx scripts/scrape-tasks.ts",
    "scrape:locations": "tsx scripts/scrape-locations.ts",
    "prepare": "husky",
    "normalize": "tsx scripts/normalize-data.ts"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^6.26.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "husky": "^9.1.7",
    "oxlint": "^1.56.0",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.10",
    "tsx": "^4.19.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.2"
  }
}
